{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generar DOCX (pandoc)",
            "type": "shell",
            "command": "pandoc",
            "args": [
                "main.tex",
                "-o", "main.docx",
                "--bibliography=bibliografia.bib",
                "--citeproc",
                "--resource-path=chapters:figures:.",
                "-M", "lang=es-ES",
                "--csl=apa.csl"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Limpiar auxiliares (latexmk -C)",
            "type": "shell",
            "command": "latexmk",
            "args": ["-C", "-outdir=build", "main.tex"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
