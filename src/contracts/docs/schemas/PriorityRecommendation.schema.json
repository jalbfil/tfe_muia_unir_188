{
  "$contractsVersion": "0.1.0",
  "$defs": {
    "ActivatedRule": {
      "additionalProperties": false,
      "properties": {
        "human_text": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Human Text",
          "type": "string"
        },
        "normative_anchors": {
          "items": {
            "$ref": "#/$defs/NormaID"
          },
          "title": "Normative Anchors",
          "type": "array"
        },
        "rule_id": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Rule Id",
          "type": "string"
        },
        "weight": {
          "title": "Weight",
          "type": "number"
        }
      },
      "required": [
        "rule_id",
        "human_text",
        "weight"
      ],
      "title": "ActivatedRule",
      "type": "object"
    },
    "ConfidenceLevel": {
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW",
        "UNKNOWN"
      ],
      "title": "ConfidenceLevel",
      "type": "string"
    },
    "ModelUsed": {
      "enum": [
        "RULEFIT",
        "BASELINE_EXPERT",
        "FALLBACK"
      ],
      "title": "ModelUsed",
      "type": "string"
    },
    "NormaID": {
      "enum": [
        "LEY_17_2015",
        "RD_524_2023",
        "PLEGEM",
        "LEY_4_2007_CYL",
        "PLANCAL_DEC_4_2019",
        "INFOCAL_DEC_6_2025",
        "INUNCYL",
        "MPCYL_ACUERDO_3_2008",
        "LEY_11_2022",
        "REGISTRO_112_CYL",
        "RGPD",
        "LOPDGDD",
        "REG_UE_2024_1689",
        "RD_840_2015_SEVESO"
      ],
      "title": "NormaID",
      "type": "string"
    },
    "Priority": {
      "enum": [
        "P1",
        "P2",
        "P3",
        "P4"
      ],
      "title": "Priority",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "activated_rules": {
      "items": {
        "$ref": "#/$defs/ActivatedRule"
      },
      "title": "Activated Rules",
      "type": "array"
    },
    "confidence_level": {
      "$ref": "#/$defs/ConfidenceLevel"
    },
    "incident_id": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Incident Id",
      "type": "string"
    },
    "model_used": {
      "$ref": "#/$defs/ModelUsed"
    },
    "model_version_capa2": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Model Version Capa2",
      "type": "string"
    },
    "priority_recommended": {
      "$ref": "#/$defs/Priority"
    },
    "probabilities": {
      "additionalProperties": {
        "maximum": 1.0,
        "minimum": 0.0,
        "type": "number"
      },
      "propertyNames": {
        "$ref": "#/$defs/Priority"
      },
      "title": "Probabilities",
      "type": "object"
    },
    "requires_human_attention": {
      "title": "Requires Human Attention",
      "type": "boolean"
    }
  },
  "required": [
    "incident_id",
    "priority_recommended",
    "probabilities",
    "confidence_level",
    "model_used",
    "model_version_capa2",
    "requires_human_attention"
  ],
  "title": "PriorityRecommendation",
  "type": "object"
}
